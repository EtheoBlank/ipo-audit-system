# IPO 审计系统环境配置示例
# 复制此文件为 .env 并填入实际值

# =====================================================================
# ⚠️ 生产部署必改 (DEBUG=false + AUTH_ENABLED=true 时缺这些会启动失败)
# =====================================================================
# 1. JWT_SECRET — 必须用强随机串 >=32 字节; 生成命令:
#    python -c "import secrets; print(secrets.token_urlsafe(48))"
# 2. AUTH_BOOTSTRAP_ADMIN_PASSWORD — 强密码, 不要用默认 Admin@1234
# 3. DEEPSEEK_API_KEY — AI 功能 (销售清单/合同/库存/函证 OCR)
# 4. MINIMAX_API_KEY  — AI 风险分析 (可选)
# 5. CORS_ORIGINS     — 改成实际域名, 不要留 localhost
# =====================================================================

# 应用设置
APP_NAME="IPO审计系统"
APP_VERSION="0.2.0"
DEBUG=true

# 服务器设置
HOST=0.0.0.0
PORT=8000

# 数据库设置
DATABASE_URL=sqlite+aiosqlite:///./ipo_audit.db

# CORS 允许的前端来源（逗号分隔）
# 生产环境请改为实际域名，不要留 *
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# MiniMax API设置 (用于AI分析功能)
# 请前往 https://platform.minimaxi.com/ 获取API Key
MINIMAX_API_KEY=your_api_key_here
MINIMAX_API_BASE=https://api.minimaxi.com/v1

# DeepSeek API 设置 (用于『销售清单整理』模块的 AI 合成 + 行业参考)
# 请前往 https://platform.deepseek.com/ 获取 API Key
# ⚠️ 请勿将此密钥提交到 Git 仓库！此文件应只作为 .env 的参考。
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 监管案例抓取 URL（一般不需要修改）
CSRC_URL=http://www.csrc.gov.cn
SSE_URL=http://www.sse.com.cn
SZSE_URL=http://www.szse.cn

# 法律法规自动抓取来源 (一般不需要修改)
MOF_URL=http://www.mof.gov.cn
MOF_ACCOUNTING_URL=http://kjs.mof.gov.cn
STA_URL=http://www.chinatax.gov.cn
SAFE_URL=http://www.safe.gov.cn
PBOC_URL=http://www.pbc.gov.cn
REGULATION_FETCH_TIMEOUT=30
REGULATION_FETCH_RETRY=2
REGULATION_MAX_PAGES=5

# 自助知识库设置
# KB_EMBEDDING_PROVIDER: tfidf (默认 / 无外部依赖) | minimax | deepseek
KB_EMBEDDING_PROVIDER=tfidf
KB_EMBEDDING_MODEL=embo-01
KB_EMBEDDING_DIM=1024
KB_CHUNK_SIZE=600
KB_CHUNK_OVERLAP=80
KB_DEFAULT_TOP_K=5
# 单本书大小上限 (字节)，默认 200MB
KB_MAX_BOOK_SIZE=209715200
# 知识库原文件目录（一般不需要修改）
KNOWLEDGE_BASE_DIR=./uploads/knowledge_base

# === 舆情跟踪 (Sentiment Tracking) — 可选 ===
# 简报/季报 .docx 落盘根
SENTIMENT_OUTPUT_DIR=./outputs/sentiment
# 调度 cron (默认 30 8 * * 1-6 = 每周一至周六 8:30, 5 字段 crontab 格式)
SENTIMENT_SCAN_CRON=30 8 * * 1-6
SENTIMENT_SCAN_TIMEZONE=Asia/Shanghai
# 单项目/单日事件抓取上限（防抓爆）
SENTIMENT_MAX_EVENTS_PER_PROJECT_PER_DAY=200
# LLM 温度（生成 / 校验）
SENTIMENT_LLM_TEMPERATURE=0.1
SENTIMENT_LLM_MAX_TOKENS=6000
SENTIMENT_VERIFY_LLM_TEMPERATURE=0.0
SENTIMENT_BRIEFING_EVENT_LOOKBACK_HOURS=36
# 付费信源 API Key — 全部留空则仅用免费源（不产生任何费用）
# 用户自行决定是否启用付费服务；本项目不对任何第三方服务做担保或推荐。
# TAVILY_API_KEY=
# BOCHA_API_KEY=
# SERPAPI_API_KEY=

# === 多用户 / 权限 / 审计轨迹 (Pack A — Phase 18) ===
# 是否启用 JWT 认证. 旧部署可保持 false (跳过认证, 兼容现网无认证调用).
# 启用后所有写端点 (POST/PUT/DELETE) 都需要 Authorization: Bearer <token>.
AUTH_ENABLED=false
# JWT 签名密钥 — 生产部署必须改成 >=32 字节随机串
# 生成: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=please-generate-a-random-secret-with-secrets-token-urlsafe-48-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
# 登录失败超过此次数自动锁定 (0=永不锁定)
AUTH_MAX_FAILED_LOGIN=10
# 首次启动若 DB 没用户则自动创建以下账号
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=Admin@1234
AUTH_BOOTSTRAP_ADMIN_FULL_NAME=系统管理员
AUTH_BOOTSTRAP_FIRM_NAME=默认事务所
# 审计轨迹: true=仅写操作落库; false=所有请求落库 (慎用, 数据量大)
AUDIT_LOG_WRITE_ONLY=true
# 审计轨迹: payload 截断到多少字符 (0=不存)
AUDIT_LOG_PAYLOAD_MAX_CHARS=4000
# 审计轨迹: 这些 path 前缀不落库
AUDIT_LOG_EXCLUDE_PATHS=/health,/docs,/redoc,/openapi.json,/favicon.ico

# === 长期资产发生额审定 (Pack A — 用户特别要求) ===
# 默认前缀清单已内置, 这里可全局额外加 / 减 (逗号分隔)
LONG_TERM_ASSET_EXTRA_INCLUDES=
LONG_TERM_ASSET_EXTRA_EXCLUDES=

# === 报告模板自定义化 (Pack A — Phase 20) ===
REPORT_TEMPLATE_DIR=./templates/reports
REPORT_OUTPUT_DIR=./outputs/reports
REPORT_TEMPLATE_MAX_SIZE=20971520
REPORT_TEMPLATE_ALLOWED_EXTS=.docx,.xlsx,.dotx,.xltx
